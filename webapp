#!/bin/bash

url="$1"
app_name="$2"

# fallback name from URL if not provided
if [ -z "$app_name" ]; then
    app_name=$(echo "$url" | sed -E 's|https?://(www\.)?([^/]+).*|\2|' | tr '.' '-')
fi

# check if window already exists
existing=$(hyprctl clients -j | jq -r ".[] | select(.class==\"$app_name\") | .address" | head -n1)

if [ -n "$existing" ]; then
    hyprctl dispatch focuswindow address:$existing
    exit 0
fi

# launch new window using Zen Browser
setsid zen-browser \
    --new-window "$url" \
    --name "$app_name" \
    --class "$app_name" >/dev/null 2>&1 &

